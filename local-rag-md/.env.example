POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=local_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=phi4-mini
OLLAMA_EMBED_MODEL=nomic-embed-text

RAG_VECTOR_DIM=768
RAG_DEFAULT_MATCH_LIMIT=8
RAG_CONTEXT_LIMIT=6
RAG_SEMANTIC_CANDIDATES=24
RAG_KEYWORD_CANDIDATES=24
RAG_RRF_K=50
RAG_BATCH_SIZE=32
RAG_CHUNK_OVERLAP=200
RAG_CHUNK_MAX_CHARS=1800
RAG_QUERY_EXPAND=true
RAG_ENABLE_TTS=false

FAISS_INDEX_PATH=./data/faiss.index
FAISS_ID_MAP_PATH=./data/faiss_ids.json

RAG_KNOWLEDGE_DIRS=%DIGITAL_LAB%
RAG_INCLUDE_GLOBS=**/*.md
RAG_EXCLUDE_GLOBS=**/node_modules/**;**/.git/**;**/.next/**;**/dist/**;**/build/**;**/.venv/**;**/venv/**;**/.agent/**;**/.agents/**;**/openjdk/**;**/nodejs_temp/**;**/local-rag-md/**

# ── OptiLLM proxy (opcional) ────────────────────────────
# Para activar: setea OPTILLM_ENABLED=true e instala optillm
OPTILLM_ENABLED=false
OPTILLM_BASE_URL=http://127.0.0.1:8001/v1
OPTILLM_DEFAULT_APPROACH=auto
OPTILLM_FAST_APPROACH=re2
OPTILLM_THINKER_APPROACH=cot_reflection
OPTILLM_CODER_APPROACH=bon

# Custom scoring configs (optional JSON files)
# RAG_LOW_VALUE_CONFIG=config/low_value_patterns.json
# RAG_BOOST_RULES_CONFIG=config/boost_rules.json
